# ─────────────────────────────────────────────────────────────────────────────
# Contract Guardian AI – Root Environment Variables Example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Leave as-is to use the built-in SQLite fallback (good for local dev).
# For production PostgreSQL, set the full connection URL:
DATABASE_URL=sqlite:///./contract_guardian.db
# DATABASE_URL=postgresql://pguser:pgpassword@db:5432/contractguardian_db

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com
# When left empty the backend automatically enters Mock Demo mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── AWS S3 (optional) ─────────────────────────────────────────────────────────
# Leave empty to save files locally inside the container volume instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend API.
# Keep this as localhost:8000 when running docker compose locally.
NEXT_PUBLIC_API_URL=http://localhost:8000
